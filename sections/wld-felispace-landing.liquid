<script>
  (function () {
    function fxAddToCart(form, dest, btn) {
      if (!form) return;
      var idEl = form.querySelector('[data-variant-input]');
      var qtyEl = form.querySelector('[data-qty-input]');
      var id = idEl ? idEl.value : '';
      var qty = qtyEl ? parseInt(qtyEl.value || '1', 10) : 1;
      if (!id) { window.location = '/cart'; return; }
      var original = btn ? btn.innerHTML : '';
      if (btn) { btn.disabled = true; btn.innerHTML = 'Adding…'; }
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: Number(id), quantity: qty }] })
      }).then(function (r) {
        if (!r.ok) { throw new Error('add failed'); }
        return r.json();
      }).then(function () {
        window.location = dest;
      }).catch(function () {
        if (btn) { btn.disabled = false; btn.innerHTML = original; }
        form.submit();
      });
    }

    function initFelispace(root) {
      if (!root) return;

      root.querySelectorAll('[data-buyform]').forEach(function (form) {
        var dataEl = form.querySelector('[data-variants-json]');
        if (!dataEl) { return; }
        var variants;
        try { variants = JSON.parse(dataEl.textContent); } catch (e) { return; }
        var input = form.querySelector('[data-variant-input]');
        function resolve() {
          var sel = [];
          form.querySelectorAll('[data-option-position]').forEach(function (grp) {
            var pos = parseInt(grp.getAttribute('data-option-position'), 10);
            var active = grp.querySelector('[data-opt-value].is-active');
            sel[pos - 1] = active ? active.getAttribute('data-value') : null;
            var lbl = form.querySelector('[data-opt-selected="' + pos + '"]');
            if (lbl && active) { lbl.textContent = active.getAttribute('data-value'); }
          });
          if (!sel.length) { return; }
          var match = variants.filter(function (v) {
            return v.options.every(function (o, i) { return o === sel[i]; });
          })[0];
          if (match && input) { input.value = match.id; }
        }
        form.querySelectorAll('[data-opt-value]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var grp = btn.closest('[data-option-position]');
            grp.querySelectorAll('[data-opt-value]').forEach(function (b) { b.classList.remove('is-active'); });
            btn.classList.add('is-active');
            resolve();
          });
        });
        resolve();
      });

      root.querySelectorAll('[data-tier-group]').forEach(function (group) {
        var form = group.closest('[data-buyform]');
        var qty = form ? form.querySelector('[data-qty-input]') : null;
        group.querySelectorAll('[data-tier]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            group.querySelectorAll('[data-tier]').forEach(function (b) { b.classList.remove('is-active'); });
            btn.classList.add('is-active');
            if (qty && btn.dataset.qty) { qty.value = btn.dataset.qty; }
          });
        });
        var active = group.querySelector('[data-tier].is-active');
        if (active && qty && active.dataset.qty) { qty.value = active.dataset.qty; }
      });

      root.querySelectorAll('[data-buynow]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          fxAddToCart(btn.closest('[data-buyform]'), '/checkout', btn);
        });
      });

      root.querySelectorAll('[data-buyform]').forEach(function (form) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          fxAddToCart(form, '/cart', form.querySelector('[data-addcart]'));
        });
      });

      root.querySelectorAll('[data-faq-q]').forEach(function (q) {
        q.addEventListener('click', function () {
          var item = q.parentElement;
          var ans = item.querySelector('.wld-felispace-faq__a');
          var open = item.classList.toggle('is-open');
          ans.style.maxHeight = open ? ans.scrollHeight + 'px' : null;
        });
      });

      root.querySelectorAll('[data-compare-tabs]').forEach(function (tabs) {
        var label = root.querySelector('[data-them-label]');
        tabs.querySelectorAll('[data-tab]').forEach(function (tab) {
          tab.addEventListener('click', function () {
            tabs.querySelectorAll('[data-tab]').forEach(function (t) { t.classList.remove('is-active'); });
            tab.classList.add('is-active');
            if (label) { label.textContent = tab.textContent; }
          });
        });
      });
    }

    var SECTION_ID = {{ section.id | json }};
    function boot() { initFelispace(document.getElementById('wld-felispace-' + SECTION_ID)); }

    if (document.readyState !== 'loading') { boot(); }
    else { document.addEventListener('DOMContentLoaded', boot); }

    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail && e.detail.sectionId === SECTION_ID) {
        initFelispace(document.getElementById('wld-felispace-' + SECTION_ID));
      }
    });
  })();
</script>

