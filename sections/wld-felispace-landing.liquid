{%- comment -%} Felispace Landing — CRO buy box v2 {%- endcomment -%}
{%- assign wld_product = section.settings.product | default: product -%}
{%- assign wld_v1 = wld_product.variants[0] -%}
{%- assign wld_default_variant = wld_product.selected_or_first_available_variant | default: wld_v1 -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<section
  id="wld-felispace-{{ section.id }}"
  class="wld-felispace"
  data-section-id="{{ section.id }}"
  style="--wld-primary: {{ section.settings.color_primary }}; --wld-accent: {{ section.settings.color_accent }}; --wld-accent2: {{ section.settings.color_accent2 }}; --wld-heading: {{ section.settings.color_heading }}; --wld-olive: {{ section.settings.color_olive }}; --wld-cream: {{ section.settings.color_cream }}; --wld-dark: {{ section.settings.color_dark }}; --wld-add: {{ section.settings.color_add }};">

  {%- if wld_product == blank -%}
    <div class="wld-felispace-no-product vel-no-product-notice">
      ⚠️ Aucun produit sélectionné. Ouvre l'éditeur de thème → réglages de cette section → choisis « la grotte Felispace » pour activer le panier.
    </div>
  {%- endif -%}

  {% comment %} ========================= HERO ========================= {% endcomment %}
  <div class="wld-felispace-hero">
    <div class="wld-felispace-hero__media">
      {%- if section.settings.hero_image != blank -%}
        <img src="{{ section.settings.hero_image | image_url: width: 900 }}" alt="{{ section.settings.product_title | escape }}" loading="eager" width="900" height="900">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'wld-felispace-placeholder' }}
      {%- endif -%}
    </div>

    <div class="wld-felispace-hero__info">
      <div class="wld-felispace-microproof">
        <span class="wld-felispace-stars">★★★★★</span>
        <strong>{{ section.settings.rating_score }}/5</strong>
        <span class="wld-felispace-microproof__sep">·</span>
        <span>{{ section.settings.rating_count }}</span>
        <span class="wld-felispace-microproof__sep">·</span>
        <span class="wld-felispace-microproof__cust">{{ section.settings.micro_customers }}</span>
      </div>

      <h1 class="wld-felispace-hero__title">{{ section.settings.product_title }}</h1>

      {%- if section.settings.benefit_intro != blank -%}
        <p class="wld-felispace-hero__intro">{{ section.settings.benefit_intro }}</p>
      {%- endif -%}

      <ul class="wld-felispace-bullets">
        {%- if section.settings.bullet_1 != blank -%}<li>{{ section.settings.bullet_1 }}</li>{%- endif -%}
        {%- if section.settings.bullet_2 != blank -%}<li>{{ section.settings.bullet_2 }}</li>{%- endif -%}
        {%- if section.settings.bullet_3 != blank -%}<li>{{ section.settings.bullet_3 }}</li>{%- endif -%}
        {%- if section.settings.bullet_4 != blank -%}<li>{{ section.settings.bullet_4 }}</li>{%- endif -%}
        {%- if section.settings.bullet_5 != blank -%}<li>{{ section.settings.bullet_5 }}</li>{%- endif -%}
      </ul>

      {%- if wld_product != blank -%}
      <form method="post" action="/cart/add" class="wld-felispace-buyform wld-felispace-card" data-buyform>
        <input type="hidden" name="id" value="{{ wld_default_variant.id }}" data-variant-input>
        <input type="hidden" name="quantity" value="2" data-qty-input>

        {%- if section.settings.urgency_stock != blank or section.settings.urgency_demand != blank -%}
        <div class="wld-felispace-urgency">
          {%- if section.settings.urgency_stock != blank -%}<span class="wld-felispace-urgency__item">⚡ {{ section.settings.urgency_stock }}</span>{%- endif -%}
          {%- if section.settings.urgency_demand != blank -%}<span class="wld-felispace-urgency__item wld-felispace-urgency__hot">🔥 {{ section.settings.urgency_demand }}</span>{%- endif -%}
        </div>
        {%- endif -%}

        {%- for opt in wld_product.options_with_values -%}
          {%- unless opt.name == 'Title' and opt.values.size == 1 -%}
          {%- assign opt_name = opt.name | downcase -%}
          {%- assign is_color = false -%}
          {%- if opt_name contains 'colour' or opt_name contains 'color' or opt_name contains 'couleur' -%}{%- assign is_color = true -%}{%- endif -%}
          <div class="wld-felispace-field">
            <label class="wld-felispace-field__label">{{ opt.name }}: <span class="wld-felispace-opt-selected" data-opt-selected="{{ opt.position }}">{{ opt.selected_value }}</span></label>
            {%- if is_color -%}
              <div class="wld-felispace-swatches" data-option-position="{{ opt.position }}">
                {%- for val in opt.values -%}
                  {%- assign cn = val | downcase -%}
                  {%- assign cdot = '#cccccc' -%}
                  {%- if cn contains 'black' or cn contains 'void' or cn contains 'noir' -%}{%- assign cdot = '#1a1a1a' -%}
                  {%- elsif cn contains 'charcoal' or cn contains 'grey' or cn contains 'gray' or cn contains 'gris' -%}{%- assign cdot = '#8a8a8a' -%}
                  {%- elsif cn contains 'pink' or cn contains 'rose' -%}{%- assign cdot = '#e89ab0' -%}
                  {%- elsif cn contains 'blue' or cn contains 'bleu' or cn contains 'sky' -%}{%- assign cdot = '#7fb0d6' -%}
                  {%- elsif cn contains 'white' or cn contains 'snow' or cn contains 'blanc' -%}{%- assign cdot = '#eeeeee' -%}
                  {%- elsif cn contains 'beige' or cn contains 'sand' -%}{%- assign cdot = '#d8c4a0' -%}
                  {%- elsif cn contains 'green' or cn contains 'sage' -%}{%- assign cdot = '#9cbf8f' -%}
                  {%- elsif cn contains 'ginger' or cn contains 'orange' -%}{%- assign cdot = '#d98a4a' -%}
                  {%- endif -%}
                  <button type="button" class="wld-felispace-swatch{% if val == opt.selected_value %} is-active{% endif %}" data-opt-value data-position="{{ opt.position }}" data-value="{{ val | escape }}" aria-label="{{ val | escape }}" title="{{ val | escape }}">
                    <span class="wld-felispace-swatch__dot" style="background: {{ cdot }};"></span>
                  </button>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="wld-felispace-optrow" data-option-position="{{ opt.position }}">
                {%- for val in opt.values -%}
                  <button type="button" class="wld-felispace-pill2{% if val == opt.selected_value %} is-active{% endif %}" data-opt-value data-position="{{ opt.position }}" data-value="{{ val | escape }}">{{ val }}</button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
          {%- endunless -%}
        {%- endfor -%}

        <script type="application/json" data-variants-json>
          [
          {%- for v in wld_product.variants -%}
            {"id": {{ v.id }}, "options": {{ v.options | json }}, "available": {{ v.available }}}{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
          ]
        </script>

        <div class="wld-felispace-field">
          <label class="wld-felispace-field__label">{{ section.settings.bundle_label }}</label>
          <div class="wld-felispace-tiers" data-tier-group>
            <button type="button" class="wld-felispace-tier" data-tier data-qty="1">
              <span class="wld-felispace-tier__radio"></span>
              <span class="wld-felispace-tier__main">
                <span class="wld-felispace-tier__title">{{ section.settings.tier1_title }}</span>
                {%- if section.settings.tier1_note != blank -%}<span class="wld-felispace-tier__note">{{ section.settings.tier1_note }}</span>{%- endif -%}
              </span>
              <span class="wld-felispace-tier__pricing">
                <span class="wld-felispace-tier__price">{{ section.settings.tier1_price }}</span>
              </span>
            </button>

            <button type="button" class="wld-felispace-tier is-active" data-tier data-qty="2">
              {%- if section.settings.tier2_badge != blank -%}<span class="wld-felispace-tier__badge">{{ section.settings.tier2_badge }}</span>{%- endif -%}
              <span class="wld-felispace-tier__radio"></span>
              <span class="wld-felispace-tier__main">
                <span class="wld-felispace-tier__title">{{ section.settings.tier2_title }}</span>
                {%- if section.settings.tier2_save != blank -%}<span class="wld-felispace-tier__save">{{ section.settings.tier2_save }}</span>{%- endif -%}
              </span>
              <span class="wld-felispace-tier__pricing">
                <span class="wld-felispace-tier__price">{{ section.settings.tier2_price }}</span>
                {%- if section.settings.tier2_compare != blank -%}<span class="wld-felispace-tier__compare">{{ section.settings.tier2_compare }}</span>{%- endif -%}
              </span>
            </button>

            <button type="button" class="wld-felispace-tier" data-tier data-qty="3">
              {%- if section.settings.tier3_badge != blank -%}<span class="wld-felispace-tier__badge wld-felispace-tier__badge--gold">{{ section.settings.tier3_badge }}</span>{%- endif -%}
              <span class="wld-felispace-tier__radio"></span>
              <span class="wld-felispace-tier__main">
                <span class="wld-felispace-tier__title">{{ section.settings.tier3_title }}</span>
                {%- if section.settings.tier3_save != blank -%}<span class="wld-felispace-tier__save">{{ section.settings.tier3_save }}</span>{%- endif -%}
              </span>
              <span class="wld-felispace-tier__pricing">
                <span class="wld-felispace-tier__price">{{ section.settings.tier3_price }}</span>
                {%- if section.settings.tier3_compare != blank -%}<span class="wld-felispace-tier__compare">{{ section.settings.tier3_compare }}</span>{%- endif -%}
              </span>
            </button>
          </div>
        </div>

        <button type="button" class="wld-felispace-cta wld-felispace-cta--buynow" data-buynow>{{ section.settings.buy_now_text }}</button>
        <button type="submit" class="wld-felispace-cta wld-felispace-cta--secondary" data-addcart>{{ section.settings.cta_text }}</button>

        <p class="wld-felispace-moneyback">🛡️ {{ section.settings.moneyback_text }}</p>

        <div class="wld-felispace-trust4">
          {%- if section.settings.badge_1 != blank -%}<div class="wld-felispace-trust4__item">{{ section.settings.badge_1 }}</div>{%- endif -%}
          {%- if section.settings.badge_2 != blank -%}<div class="wld-felispace-trust4__item">{{ section.settings.badge_2 }}</div>{%- endif -%}
          {%- if section.settings.badge_3 != blank -%}<div class="wld-felispace-trust4__item">{{ section.settings.badge_3 }}</div>{%- endif -%}
          {%- if section.settings.badge_4 != blank -%}<div class="wld-felispace-trust4__item">{{ section.settings.badge_4 }}</div>{%- endif -%}
        </div>
      </form>
      {%- else -%}
        <button type="button" class="wld-felispace-cta is-disabled" disabled>{{ section.settings.cta_text }}</button>
      {%- endif -%}
    </div>
  </div>

  {% comment %} ============ SOCIAL PROOF + VIDÉOS ============ {% endcomment %}
  <div class="wld-felispace-band wld-felispace-band--cream">
    <h2 class="wld-felispace-h2">{{ section.settings.social_title }}</h2>
    <p class="wld-felispace-sub">{{ section.settings.social_sub }}</p>

    {%- assign vid_count = 0 -%}
    {%- for block in section.blocks -%}{%- if block.type == 'video' -%}{%- assign vid_count = vid_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
    {%- if vid_count > 0 -%}
      <div class="wld-felispace-videos">
        {%- for block in section.blocks -%}
          {%- if block.type == 'video' -%}
            <div class="wld-felispace-vid" {{ block.shopify_attributes }}>
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: image_size: '500x', loop: true, controls: true, muted: true, playsinline: true }}
              {%- elsif block.settings.poster != blank -%}
                <img src="{{ block.settings.poster | image_url: width: 500 }}" alt="" loading="lazy" width="500" height="700">
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'wld-felispace-placeholder' }}
              {%- endif -%}
              {%- if block.settings.caption != blank -%}<span class="wld-felispace-vid__cap">{{ block.settings.caption }}</span>{%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="wld-felispace-trust-strip">
      <div class="wld-felispace-trust"><span>🚚</span>{{ section.settings.trust_1 }}</div>
      <div class="wld-felispace-trust"><span>✅</span>{{ section.settings.trust_2 }}</div>
      <div class="wld-felispace-trust"><span>🔒</span>{{ section.settings.trust_3 }}</div>
      <div class="wld-felispace-trust"><span>🐾</span>{{ section.settings.trust_4 }}</div>
    </div>
  </div>

  {% comment %} ================= WHY CHOOSE ================= {% endcomment %}
  <div class="wld-felispace-band wld-felispace-band--accent">
    <h2 class="wld-felispace-h2">{{ section.settings.why_title }}</h2>
    <div class="wld-felispace-why">
      <div class="wld-felispace-why__col">
        <div class="wld-felispace-why__item"><span class="wld-felispace-why__ico">🛡️</span><div><h3>{{ section.settings.why_1_title }}</h3><p>{{ section.settings.why_1_text }}</p></div></div>
        <div class="wld-felispace-why__item"><span class="wld-felispace-why__ico">🌿</span><div><h3>{{ section.settings.why_2_title }}</h3><p>{{ section.settings.why_2_text }}</p></div></div>
      </div>
      <div class="wld-felispace-why__media">
        {%- if section.settings.why_image != blank -%}
          <img src="{{ section.settings.why_image | image_url: width: 700 }}" alt="" loading="lazy" width="700" height="700">
        {%- else -%}
          {{ 'product-2' | placeholder_svg_tag: 'wld-felispace-placeholder' }}
        {%- endif -%}
      </div>
      <div class="wld-felispace-why__col">
        <div class="wld-felispace-why__item"><span class="wld-felispace-why__ico">💪</span><div><h3>{{ section.settings.why_3_title }}</h3><p>{{ section.settings.why_3_text }}</p></div></div>
        <div class="wld-felispace-why__item"><span class="wld-felispace-why__ico">🧼</span><div><h3>{{ section.settings.why_4_title }}</h3><p>{{ section.settings.why_4_text }}</p></div></div>
      </div>
    </div>
  </div>

  {% comment %} ================= REVIEWS (blocks) ================= {% endcomment %}
  <div class="wld-felispace-band wld-felispace-band--dark">
    <h2 class="wld-felispace-h2 wld-felispace-h2--light">{{ section.settings.reviews_title }}</h2>
    <div class="wld-felispace-reviews">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <article class="wld-felispace-review" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img class="wld-felispace-review__img" src="{{ block.settings.image | image_url: width: 360 }}" alt="" loading="lazy" width="360" height="270">
            {%- endif -%}
            <div class="wld-felispace-review__stars">{% for s in (1..block.settings.rating) %}★{% endfor %}</div>
            <h4 class="wld-felispace-review__title">{{ block.settings.title }}</h4>
            <p class="wld-felispace-review__text">{{ block.settings.text }}</p>
            <span class="wld-felispace-review__author">{{ block.settings.author }}</span>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if wld_product != blank -%}
      <a href="#wld-felispace-buybox-{{ section.id }}" class="wld-felispace-cta wld-felispace-cta--inline">{{ section.settings.shop_now_text }}</a>
    {%- endif -%}
  </div>

  {% comment %} ================= BENEFITS ================= {% endcomment %}
  <div class="wld-felispace-band wld-felispace-band--dark">
    <h2 class="wld-felispace-h2 wld-felispace-h2--light">{{ section.settings.benefits_title }}</h2>
    <div class="wld-felispace-benefits">
      <div class="wld-felispace-benefit"><span class="wld-felispace-benefit__icon">😴</span><h3>{{ section.settings.benefit_1_title }}</h3><p>{{ section.settings.benefit_1_text }}</p></div>
      <div class="wld-felispace-benefit"><span class="wld-felispace-benefit__icon">🐾</span><h3>{{ section.settings.benefit_2_title }}</h3><p>{{ section.settings.benefit_2_text }}</p></div>
      <div class="wld-felispace-benefit"><span class="wld-felispace-benefit__icon">🧶</span><h3>{{ section.settings.benefit_3_title }}</h3><p>{{ section.settings.benefit_3_text }}</p></div>
    </div>
    {%- if wld_product != blank -%}
      <a href="#wld-felispace-buybox-{{ section.id }}" class="wld-felispace-cta wld-felispace-cta--inline">{{ section.settings.shop_now_text }}</a>
    {%- endif -%}
  </div>

  {% comment %} ================= US VS. ================= {% endcomment %}
  <div class="wld-felispace-band wld-felispace-band--cream">
    <h2 class="wld-felispace-h2">{{ section.settings.compare_title }}</h2>
    <div class="wld-felispace-compare">
      <div class="wld-felispace-compare__tabs" data-compare-tabs>
        <button type="button" class="wld-felispace-tab is-active" data-tab>{{ section.settings.compare_tab_1 }}</button>
        <button type="button" class="wld-felispace-tab" data-tab>{{ section.settings.compare_tab_2 }}</button>
        <button type="button" class="wld-felispace-tab" data-tab>{{ section.settings.compare_tab_3 }}</button>
      </div>
      <table class="wld-felispace-table">
        <thead>
          <tr><th></th><th class="wld-felispace-table__ours">{{ section.settings.compare_ours }}</th><th class="wld-felispace-table__them" data-them-label>{{ section.settings.compare_tab_1 }}</th></tr>
        </thead>
        <tbody>
          {%- assign rows = section.settings.compare_rows | newline_to_br | split: '<br />' -%}
          {%- for row in rows -%}
            {%- assign r = row | strip -%}
            {%- if r != blank -%}
              <tr><td>{{ r }}</td><td class="wld-felispace-yes">✓</td><td class="wld-felispace-no">✕</td></tr>
            {%- endif -%}
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>

  {% comment %} ================= BUY BOX 2 ================= {% endcomment %}
  {%- if wld_product != blank -%}
  <div id="wld-felispace-buybox-{{ section.id }}" class="wld-felispace-band wld-felispace-band--accent">
    <h2 class="wld-felispace-h2">{{ section.settings.buybox_title }}</h2>
    <form method="post" action="/cart/add" class="wld-felispace-buybox wld-felispace-card" data-buyform>
      <input type="hidden" name="id" value="{{ wld_default_variant.id }}" data-variant-input>
      <input type="hidden" name="quantity" value="2" data-qty-input>
      <div class="wld-felispace-tiers" data-tier-group>
        <button type="button" class="wld-felispace-tier" data-tier data-qty="1">
          <span class="wld-felispace-tier__radio"></span>
          <span class="wld-felispace-tier__main">
            <span class="wld-felispace-tier__title">{{ section.settings.tier1_title }}</span>
            {%- if section.settings.tier1_note != blank -%}<span class="wld-felispace-tier__note">{{ section.settings.tier1_note }}</span>{%- endif -%}
          </span>
          <span class="wld-felispace-tier__pricing"><span class="wld-felispace-tier__price">{{ section.settings.tier1_price }}</span></span>
        </button>
        <button type="button" class="wld-felispace-tier is-active" data-tier data-qty="2">
          {%- if section.settings.tier2_badge != blank -%}<span class="wld-felispace-tier__badge">{{ section.settings.tier2_badge }}</span>{%- endif -%}
          <span class="wld-felispace-tier__radio"></span>
          <span class="wld-felispace-tier__main">
            <span class="wld-felispace-tier__title">{{ section.settings.tier2_title }}</span>
            {%- if section.settings.tier2_save != blank -%}<span class="wld-felispace-tier__save">{{ section.settings.tier2_save }}</span>{%- endif -%}
          </span>
          <span class="wld-felispace-tier__pricing">
            <span class="wld-felispace-tier__price">{{ section.settings.tier2_price }}</span>
            {%- if section.settings.tier2_compare != blank -%}<span class="wld-felispace-tier__compare">{{ section.settings.tier2_compare }}</span>{%- endif -%}
          </span>
        </button>
        <button type="button" class="wld-felispace-tier" data-tier data-qty="3">
          {%- if section.settings.tier3_badge != blank -%}<span class="wld-felispace-tier__badge wld-felispace-tier__badge--gold">{{ section.settings.tier3_badge }}</span>{%- endif -%}
          <span class="wld-felispace-tier__radio"></span>
          <span class="wld-felispace-tier__main">
            <span class="wld-felispace-tier__title">{{ section.settings.tier3_title }}</span>
            {%- if section.settings.tier3_save != blank -%}<span class="wld-felispace-tier__save">{{ section.settings.tier3_save }}</span>{%- endif -%}
          </span>
          <span class="wld-felispace-tier__pricing">
            <span class="wld-felispace-tier__price">{{ section.settings.tier3_price }}</span>
            {%- if section.settings.tier3_compare != blank -%}<span class="wld-felispace-tier__compare">{{ section.settings.tier3_compare }}</span>{%- endif -%}
          </span>
        </button>
      </div>
      <button type="button" class="wld-felispace-cta wld-felispace-cta--buynow" data-buynow>{{ section.settings.buy_now_text }}</button>
      <button type="submit" class="wld-felispace-cta wld-felispace-cta--secondary" data-addcart>{{ section.settings.cta_text }}</button>
      <p class="wld-felispace-moneyback">🛡️ {{ section.settings.moneyback_text }}</p>
    </form>
  </div>
  {%- endif -%}

  {% comment %} ================= FAQ ================= {% endcomment %}
  <div class="wld-felispace-band wld-felispace-band--cream">
    <h2 class="wld-felispace-h2">{{ section.settings.faq_title }}</h2>
    <div class="wld-felispace-faq" data-faq>
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
          <div class="wld-felispace-faq__item" {{ block.shopify_attributes }}>
            <button type="button" class="wld-felispace-faq__q" data-faq-q>{{ block.settings.question }}<span class="wld-felispace-faq__icon">+</span></button>
            <div class="wld-felispace-faq__a"><p>{{ block.settings.answer }}</p></div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {% comment %} ================= GUARANTEE BANNER ================= {% endcomment %}
  <div class="wld-felispace-promise">
